      "source": [
        "def process_result(marks):\n",
        "    total = 0\n",
        "    for mark in marks:\n",
        "        total += mark\n",
        "    average = total / len(marks)\n",
        "    if average >= 50:\n",
        "        return \"Pass\"\n",
        "    else:\n",
        "        return \"Fail\"\n",
        "marks = [60, 45, 70, 55]\n",
        "result = process_result(marks)\n",
        "print(\"Result:\", result)"
      ]
    }
  ]
